# ============================================================
# EchoScript Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# --- Device & Model ---
ECHOSCRIPT_DEVICE=cuda
HF_HOME=~/.cache/huggingface

# --- Tesseract OCR ---
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANGS=eng,hin,ara,fra,deu,spa,chi_sim,jpn,kor

# --- Audio Output ---
OUTPUT_DIR=./backend/output
MAX_OUTPUT_FILES=100

# --- Reference Voice Clips ---
MALE_VOICE_PATH=./backend/assets/voices/male_reference.wav
FEMALE_VOICE_PATH=./backend/assets/voices/female_reference.wav

# --- TTS Defaults ---
DEFAULT_CFG_WEIGHT=0.5
DEFAULT_EXAGGERATION=0.5
MAX_CHUNK_WORDS=400

# --- FastAPI Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend ---
VITE_API_URL=http://localhost:8000
